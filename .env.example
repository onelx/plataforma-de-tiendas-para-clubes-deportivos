# ===========================================
# Supabase Configuration
# Get these from your Supabase project settings
# ===========================================

# Supabase Project URL
# Found in: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (public, safe for client)
# Found in: Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (secret, server-only)
# Found in: Project Settings > API > Project API keys > service_role
# WARNING: Never expose this on the client side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Stripe Configuration
# Get these from your Stripe Dashboard
# ===========================================

# Stripe Publishable Key (public, safe for client)
# Found in: Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Secret Key (secret, server-only)
# Found in: Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe Webhook Secret
# Get this when setting up webhooks in Stripe Dashboard
# For local dev, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# Application Configuration
# ===========================================

# Base URL of your application
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform commission percentage (e.g., 15 means 15%)
PLATFORM_COMMISSION_PERCENTAGE=15

# ===========================================
# Optional: Email Configuration (for notifications)
# ===========================================

# Resend API Key (if using Resend for emails)
# RESEND_API_KEY=re_your-api-key

# ===========================================
# Optional: Storage Configuration
# ===========================================

# If using external storage for images
# CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name
