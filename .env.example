# Supabase Configuration
# Obtené estos valores en: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Configuration
# Obtené estos valores en: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform Configuration
# URL base de tu aplicación (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comisión por defecto de la plataforma (porcentaje)
PLATFORM_COMMISSION_PERCENTAGE=15

# Email Configuration (opcional, para notificaciones)
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL_FROM=notificaciones@tudominio.com

# Storage Configuration
# Bucket de Supabase para imágenes de productos
NEXT_PUBLIC_STORAGE_BUCKET=productos

# Feature Flags (opcional)
ENABLE_STRIPE_CONNECT=true
ENABLE_EMAIL_NOTIFICATIONS=false
